.siege.p-2.relative.auto-rows-max
	input.settings-siege(type='hidden' name="attr_toggle_siege_settings")
	input.edit-siege(type="hidden" name="attr_toggle_edit_siege_edit" value="true")
	input.sections(type="hidden" name="attr_siege_sections" value="actions")

	.grid.grid-flow-col.auto-cols-min.gap-2.settings-toggle.absolute
		.grid.relative.grid-flow-col.auto-cols-min.gap-2
			+editToggle('siege edit', true)
		.grid.relative.grid-flow-col.auto-cols-min.gap-2
			+settingsToggle('siege settings')
	.grid.gap-4.sheet
		.display-mode
			span.display(name="attr_character_name")
			.grid.col-auto-fr.gap-1.grid-flow-col.items-center
				+attrSpan("description")
		.inputs.grid.gap-2
			.grid.gap-2.grid-flow-col.bio
				.grid.grid-flow-col.gap-2
					+headerInput('character name')
			.grid.gap-2
				+h3Header("description")
				+textarea("description")

		.display-mode.grid.gap-4
			.grid.auto-rows-min
				each val in ["range", "ammunition", "reload"]
					.grid.gap-2.grid-flow-col.auto-cols-max.items-center
						+h3Header(val)
						+attrSpan(val)
				.grid.gap-1.grid-flow-col.col-auto-fr.display-span
					+h3Header("AOE")
					+attrSpan("area of effect")
				each val in["helf", "speed", "hp" ]
					.grid.gap-2.grid-flow-col.auto-cols-max.items-center.display-span
						+h3Header(val)
						+attrSpan(val)
				.grid.gap-4.grid-flow-col.items-center.auto-cols-max
					each val in [["armor rating", "AR"], ["reflexes", "REF"], ["fortitude", "FORT"]]
						- const [name, label] = val;
						.grid.gap-2.grid-flow-col.auto-cols-min
							+h3Header(label).text-left
							+attrSpan(name)
				.resist.grid.gap-2.grid-flow-col.items-center
					each val in ["resist", "immune"]
						.grid.gap-2.grid-flow-col.auto-cols-max.display-span
							+h3Header(val).text-left
							+attrSpan(val)
				.grid.gap-2.grid-flow-col.items-center.auto-cols-max.display-span
					+h3Header("vulnerable").text-left
					+attrSpan("vulnerable")
				.grid.gap-2.grid-flow-col.items-center
					each val in [["damage_reduction", "DR"], ["damage_threshold", "DT"]]
						- const [name, label] = val;
						.grid.gap-2.grid-flow-col.auto-cols-max.display-span
							+h3Header(label)
							+attrSpan(name)

		.inputs.grid.gap-4
			.grid.grid-gap-2.grid-flow-col.items-center
				+headerInput("range")
			.grid.gap-2.items-center.grid-flow-col
				each val in ["ammunition", "reload"]
					.grid.grid-gap-2.grid-flow-col.items-center
						+headerInput(val)
			each val in [ "area of effect", "helf"]
				.grid.grid-gap-2.grid-flow-col.items-center
					+headerInput(val)
			.grid.gap-2.items-center.grid-flow-col
				each val in ["speed", "hp"]
					.grid.grid-gap-2.grid-flow-col.items-center
						+headerInput(val)
			.grid.gap-2.items-center.grid-flow-col
				each val in ["armor rating", "reflexes", "fortitude"]
					.grid.grid-gap-2.grid-flow-col.items-center
						+headerInput(val)
			.grid.gap-2.items-center.grid-flow-col
				each val in ["resist", "immune"]
					.grid.grid-gap-2.grid-flow-col.items-center
						+headerInput(val)
			.grid.gap-2.items-center.grid-flow-col
				each val in ["vulnerable"]
					.grid.grid-gap-2.grid-flow-col.items-center
						+headerInput(val)
			.grid.gap-2.items-center.grid-flow-col
				each val in ["damage reduction", "damage threshold"]
					.grid.grid-gap-2.grid-flow-col.items-center
						+headerInput(val)


		.grid.gap-2.items-center.actions.section-actions
			.grid.gap-2.header-toggle
				h2.ellipse.uppercase.text-primary(data-i18n="actions")
				label.switch(data-i18n-title="toggle actions")
					input(type="checkbox" name="attr_section_actions")
					span.slider
			.display-mode.mb-2
				i
					span(name='attr_action_description')
			.inputs
				textarea(name='attr_action_description' title='@{action_description}')
			fieldset(class=`repeating_actions`)
				input(type="hidden" name="attr_roll_formula" value=`{{description=@{effect} @{description}}}`)
				+repeatingCreatureEffect('effect')
				.grid.gap-2.relative.repeating-grid
					input(type='hidden' name='attr_name')
					.grid.grid-flow-col.gap-2.displayed.custom-grid
						span.or.font-bold(name="attr_name")
						span.or(name="attr_description")
						input(type="hidden" name="attr_toggle_action_attack")
						p
							+repeatingAttackRollButton('name')
							span(name='attr_description') 
							+attrSpan("range")(class="italic")
							+attrSpan("type")(class="italic")
							+attrSpan("modifier")
							span.vs vs
							+attrSpan("defense")
							span.hit.font-bold.capitalize(data-i18n="Hit:")
							+attrSpan("damage average")(class="text-center mr-1")
							+repeatingCreatureDamageButton("damage")
							+attrSpan("damage type")(class="ml-1")
							+attrSpan("effect")
					+editToggle()
					.edit.grid.gap-2
						.grid.gap-2.grid-flow-col.col-fr-auto
							+headerInput('name')
							.grid.gap-2.grid-flow-col.items-center.attack-toggle.auto-cols-min
								+h3Header("attack")
								label.switch(data-i18n-title="toggle attack")
									input(type="checkbox" name="attr_toggle_action_attack")
									span.slider
						.grid.gap-2.grid-flow-col.range
							each val in ['range', 'type']
								+headerInput(val)
						.grid.gap-2.grid-flow-col.items-center.modifier
							+headerInput('modifier')(class="text-center")
							span vs
							+headerInput('defense')
						.grid.gap-2.grid-flow-col.damage
							+h3Header("Hit")
							.grid.col-auto-fr.gap-1.grid-flow-col.items-center
								+h3Header("damage")
								.grid.grid-flow-col.items-center.dmg
									+textInput('damage average')(class="text-center")
									.grid.grid-flow-col.items-center
										span (
										+textInput('damage')
										span )
							+headerInput('damage type', 'type')
						+headerInput('effect')
						.description
							+textarea('description')


	.grid.gap-4.settings 
		.grid.gap-2
			h2.ellipse.capitalize(data-i18n="character type")
			+sheetSelect()
